const fmt=(n:number)=>{const abs=Math.abs(n);return(n<0?"-":"")+( abs>=100000000?`${(abs/100000000).toFixed(1)}억`:abs>=10000?`${Math.round(abs/10000)}만`:Math.round(abs).toLocaleString("ko-KR"))+"원";};
const fmtFull=(n:number)=>Math.round(n).toLocaleString("ko-KR");
const getLevel=(exp:number)=>Math.floor(exp/200)+1;
const calcExp=(p:number)=>p>500000?30:p>0?15:p>-200000?5:0;

function getWeather(day:number):Weather{
  const r=Math.random(),s=Math.floor(((day-1)%90)/22);
  if(s===1){if(r<0.3)return"hot";if(r<0.55)return"rainy";return"sunny";}
  if(s===3){if(r<0.25)return"snow";if(r<0.5)return"cloudy";return"rainy";}
  if(r<0.4)return"sunny";if(r<0.65)return"cloudy";return"rainy";
}

function calcDay(s:GameState){
  const wm=W[s.weather].mod,rm=0.6+(s.reputation/100)*0.8;
  const as=s.staff.filter(x=>!x.absent).reduce((a,x)=>a+x.skill,0)/Math.max(s.staff.filter(x=>!x.absent).length,1);
  const sm=0.65+(as/100)*0.7;
  const isWknd=((s.day-1)%7)>=5,wkMod=isWknd?1.4:1.0;
  const areaMod=AREA_MOD[s.area.areaType]*(1+(s.area.footTraffic-3)*0.08)*(1-(s.area.competition-3)*0.05)*(s.area.nearStation?1.1:1)*(s.area.parking?1.05:1);
  let cm=wm*rm*sm*wkMod*areaMod,spm=1.0,cgm=0;
  for(const e of s.pendingEffects){
    if(e.type==="customers")cm*=(1+e.value);
    if(e.type==="avgSpend")spm*=(1+e.value);
    if(e.type==="cogsRate")cgm+=e.value;
  }
  const customers=Math.max(0,Math.round(s.baseCustomers*cm*(0.8+Math.random()*0.4)));
  const spend=s.avgSpend*spm*(0.9+Math.random()*0.2);
  const revenue=customers*spend;
  const cogs=revenue*(Math.min(s.cogsRate+cgm,95)/100);
  const labor=s.staff.filter(x=>!x.absent).reduce((a,x)=>a+x.wage,0);
  const fixed=s.day%30===0?(s.rent+s.utilities):0;
  const cost=cogs+revenue*0.015+labor+fixed;
  return{customers:Math.round(customers),revenue:Math.round(revenue),cost:Math.round(cost),profit:Math.round(revenue-cost)};
}

