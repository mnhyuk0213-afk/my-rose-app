function GamePlay({state,setState,onGameOver,onSave}:{state:GameState;setState:React.Dispatch<React.SetStateAction<GameState|null>>;onGameOver:()=>void;onSave:()=>void;}){
  const [floats,setFloats]=useState<FloatingText[]>([]);
  const [showSaveMenu,setShowSaveMenu]=useState(false);
  const [levelUp,setLevelUp]=useState<number|null>(null);
  const fid=useRef(0);
  const cfg=IND[state.industry];
  const isWeekend=((state.day-1)%7)>=5;
  const level=getLevel(state.exp);

  const addFloat=useCallback((text:string,color:string)=>{
    const id=++fid.current;
    setFloats(p=>[...p,{id,text,x:20+Math.random()*60,color}]);
    setTimeout(()=>setFloats(p=>p.filter(f=>f.id!==id)),1600);
  },[]);

  const openDay=useCallback(()=>{
    const ev=Math.random()<0.42?ALL_EVENTS[Math.floor(Math.random()*ALL_EVENTS.length)]:null;
    if(ev){setState(s=>s?{...s,currentEvent:ev,phase:"event"}:s);return;}
    const res=calcDay(state);
    const eg=calcExp(res.profit);
    const newExp=state.exp+eg;
    const newLevel=getLevel(newExp);
    if(newLevel>level)setLevelUp(newLevel);
    setState(s=>{
      if(!s)return s;
      const ne=s.pendingEffects.map(e=>({...e,duration:e.duration>0?e.duration-1:e.duration})).filter(e=>e.duration!==0);
      const newStreak=res.profit>0?s.streak+1:0;
      return{...s,cash:s.cash+res.profit,totalRevenue:s.totalRevenue+res.revenue,totalProfit:s.totalProfit+res.profit,
        todayCustomers:res.customers,todayRevenue:res.revenue,todayCost:res.cost,todayProfit:res.profit,
        logs:[...s.logs,{day:s.day,weather:s.weather,customers:res.customers,revenue:res.revenue,profit:res.profit}],
        phase:"result",pendingEffects:ne,exp:newExp,streak:newStreak,bestDay:Math.max(s.bestDay,res.profit)};
    });
    addFloat(res.profit>=0?`+${fmt(res.profit)} 💰`:`${fmt(res.profit)} 😢`,res.profit>=0?GREEN_M:RED_M);
  },[state,addFloat,level]);

  const handleChoice=useCallback((idx:number)=>{
    if(!state?.currentEvent)return;
    const ch=state.currentEvent.choices[idx];
    if(ch.cost&&state.cash<ch.cost){alert(`현금 부족! (필요: ${fmtFull(ch.cost)}원)`);return;}
    const result=ch.apply(state);
    const neff=result.effects??[];
    const tmp:GameState={...state,...result,cash:state.cash-(ch.cost??0),pendingEffects:[...state.pendingEffects,...neff],currentEvent:null};
    const res=calcDay(tmp);
    const eg=calcExp(res.profit);
    const decay=tmp.pendingEffects.map(e=>({...e,duration:e.duration>0?e.duration-1:e.duration})).filter(e=>e.duration!==0);
    const newStreak=res.profit>0?tmp.streak+1:0;
    setState({...tmp,cash:tmp.cash+res.profit,totalRevenue:tmp.totalRevenue+res.revenue,totalProfit:tmp.totalProfit+res.profit,
      todayCustomers:res.customers,todayRevenue:res.revenue,todayCost:res.cost,todayProfit:res.profit,
      logs:[...state.logs,{day:state.day,weather:state.weather,customers:res.customers,revenue:res.revenue,profit:res.profit,event:state.currentEvent!.title}],
      phase:"result",pendingEffects:decay,exp:tmp.exp+eg,streak:newStreak,bestDay:Math.max(tmp.bestDay,res.profit)});
    addFloat(res.profit>=0?`+${fmt(res.profit)} 💰`:`${fmt(res.profit)} 😢`,res.profit>=0?GREEN_M:RED_M);
  },[state,addFloat]);

  const nextDay=useCallback(()=>{
    if(!state)return;
    if(state.cash<-5000000||state.day>=state.maxDays){onGameOver();return;}
    const nd=state.day+1;
    const newState={...state,day:nd,phase:"morning" as DayPhase,weather:getWeather(nd),currentEvent:null,
      staff:state.staff.map(st=>({...st,mood:Math.min(Math.max(st.mood+(Math.random()>0.7?3:-1),0),100),absent:Math.random()<0.025}))};
    setState(newState);
    saveGame(newState);
  },[state,onGameOver]);

  const typeColor=state.currentEvent?.type==="crisis"
    ?{bg:RED_L,border:"#FECACA",text:RED_M,lbg:"#FEE2E2",label:"⚠️ 위기!"}
    :state.currentEvent?.type==="opportunity"
    ?{bg:GREEN_L,border:"#A7F3D0",text:GREEN_M,lbg:"#D1FAE5",label:"✨ 기회!"}
    :{bg:G50,border:G200,text:G800,lbg:G100,label:"📢 이벤트"};

  const busyLevel=Math.min(state.todayCustomers/(state.baseCustomers*1.5),1);
  const custCount=state.phase==="result"?Math.round(busyLevel*6):0;

  return(
    <div style={{minHeight:"100vh",background:G50,fontFamily:"'Pretendard',sans-serif"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;500;600;700;800;900&display=swap');
        @keyframes bobble{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
        @keyframes floatUp{0%{transform:translateY(0);opacity:1}100%{transform:translateY(-80px);opacity:0}}
        @keyframes popIn{0%{transform:scale(0.9);opacity:0}100%{transform:scale(1);opacity:1}}
        @keyframes slideUp{0%{transform:translateY(20px);opacity:0}100%{transform:translateY(0);opacity:1}}
        @keyframes rain{0%{transform:translateY(-20px);opacity:0}80%{opacity:0.6}100%{transform:translateY(190px);opacity:0}}
        @keyframes snow{0%{transform:translateY(-10px) rotate(0deg);opacity:0}100%{transform:translateY(190px) rotate(360deg);opacity:0}}
        @keyframes levelup{0%{transform:scale(0.5);opacity:0}50%{transform:scale(1.2)}100%{transform:scale(1);opacity:1}}
      `}</style>

      <GameNavBar/>

      {/* 레벨업 알림 */}
      {levelUp&&(
        <div style={{position:"fixed",top:"50%",left:"50%",transform:"translate(-50%,-50%)",zIndex:200,textAlign:"center",animation:"levelup 0.6s ease-out",pointerEvents:"none"}}>
          <div style={{background:"#fff",borderRadius:24,padding:"28px 40px",boxShadow:"0 20px 60px rgba(0,0,0,0.15)",border:`2px solid ${BLUE}`}}>
            <div style={{fontSize:48,marginBottom:8}}>⬆️</div>
            <p style={{fontSize:28,fontWeight:800,color:BLUE,margin:"0 0 4px"}}>LEVEL UP!</p>
            <p style={{fontSize:18,color:G600,margin:0}}>LV.{levelUp} 달성!</p>
          </div>
        </div>
      )}
      {levelUp&&setTimeout(()=>setLevelUp(null),2000)&&null}

      <div style={{maxWidth:520,margin:"0 auto",padding:"16px"}}>

        {/* HUD */}
        <div style={{...card,marginBottom:10,borderColor:cfg.color+"44"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:12}}>
            <div style={{display:"flex",alignItems:"center",gap:10}}>
              <div style={{background:cfg.color,borderRadius:10,padding:"5px 12px",fontSize:13,fontWeight:800,color:"#fff"}}>LV.{level}</div>
              <div>
                <p style={{fontSize:16,fontWeight:800,color:G900,margin:0}}>{state.day}일차 {isWeekend?"🎉 주말":""}</p>
                <p style={{fontSize:12,color:G400,margin:0}}>{W[state.weather].icon} {W[state.weather].label} · {state.maxDays-state.day}일 남음</p>
              </div>
            </div>
            <div style={{textAlign:"right"}}>
              <p style={{fontSize:11,color:G400,margin:0}}>보유 현금</p>
              <p style={{fontSize:17,fontWeight:800,color:state.cash>=0?G900:RED_M,margin:0}}>{fmtFull(state.cash)}원</p>
            </div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:12}}>
            {[{l:"💰 누적 순이익",v:fmt(state.totalProfit),c:state.totalProfit>=0?GREEN_M:RED_M},{l:"⭐ 평판",v:`${state.reputation}점`,c:"#F59E0B"},{l:"🔥 연속 흑자",v:`${state.streak}일`,c:state.streak>=3?BLUE:G600}].map(s=>(
              <div key={s.l} style={{background:G50,borderRadius:10,padding:"10px 12px"}}>
                <p style={{fontSize:11,color:G400,margin:"0 0 3px"}}>{s.l}</p>
                <p style={{fontSize:14,fontWeight:700,color:s.c,margin:0}}>{s.v}</p>
              </div>
            ))}
          </div>
          {/* 진행 바 */}
          <div style={{background:G100,borderRadius:4,height:6,overflow:"hidden",marginBottom:8}}>
            <div style={{height:"100%",width:`${(state.day/state.maxDays)*100}%`,background:cfg.color,borderRadius:4,transition:"width 0.5s"}}/>
          </div>
          {/* 진행 중인 효과 */}
          {state.pendingEffects.length>0&&(
            <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
              {state.pendingEffects.slice(0,4).map((e,i)=>(
                <span key={i} style={{...tag(e.value>0?GREEN_M:RED_M,e.value>0?GREEN_L:RED_L)}}>
                  {e.value>0?"▲":"▼"} {e.label} {e.duration>0?`${e.duration}일`:"∞"}
                </span>
              ))}
            </div>
          )}
          {/* 저장 메뉴 */}
          <div style={{marginTop:10,display:"flex",justifyContent:"flex-end",gap:6}}>
            <button onClick={()=>{onSave();setShowSaveMenu(false);}} style={{fontSize:12,color:G400,background:"none",border:`1px solid ${G200}`,borderRadius:8,padding:"4px 10px",cursor:"pointer",fontFamily:"'Pretendard',sans-serif"}}>💾 저장</button>
            <button onClick={()=>{if(confirm("정말 종료하시겠어요? (저장됩니다)"))onGameOver();}} style={{fontSize:12,color:G400,background:"none",border:`1px solid ${G200}`,borderRadius:8,padding:"4px 10px",cursor:"pointer",fontFamily:"'Pretendard',sans-serif"}}>🚪 나가기</button>
          </div>
        </div>

        {/* 매장 씬 */}
        <div style={{position:"relative",borderRadius:20,overflow:"hidden",background:W[state.weather].icon==="☀️"?"#FFF9E6":W[state.weather].icon==="🌧️"?"#EFF6FF":W[state.weather].icon==="❄️"?"#F0F9FF":W[state.weather].icon==="🥵"?"#FFF7ED":"#F8FAFC",border:`1px solid ${cfg.color}44`,height:190,marginBottom:10}}>
          {state.weather==="rainy"&&[...Array(7)].map((_,i)=>(
            <div key={i} style={{position:"absolute",top:0,left:`${8+i*13}%`,width:1.5,height:14,background:"#93C5FD",animation:`rain ${0.7+i*0.08}s linear infinite`,animationDelay:`${i*0.12}s`}}/>
          ))}
          {state.weather==="snow"&&[...Array(6)].map((_,i)=>(
            <div key={i} style={{position:"absolute",top:0,left:`${5+i*16}%`,fontSize:14,opacity:0.6,animation:`snow ${1.8+i*0.2}s linear infinite`,animationDelay:`${i*0.25}s`}}>❄️</div>
          ))}
          {state.weather==="sunny"&&<div style={{position:"absolute",top:10,right:16,fontSize:28,opacity:0.7}}>☀️</div>}
          {state.weather==="hot"&&<div style={{position:"absolute",top:10,right:16,fontSize:24,opacity:0.7}}>🌡️</div>}
          {/* 매장 간판 */}
          <div style={{position:"absolute",top:12,left:0,right:0,textAlign:"center"}}>
            <span style={{background:cfg.color,color:"#fff",borderRadius:20,padding:"5px 18px",fontSize:14,fontWeight:800,letterSpacing:-0.3}}>{state.storeName}</span>
          </div>
          {/* 직원 */}
          <div style={{position:"absolute",bottom:42,left:16,display:"flex",gap:8,alignItems:"flex-end"}}>
            <div style={{fontSize:34}}>{cfg.icon}</div>
            {state.staff.filter(s=>!s.absent).map((s,i)=>(
              <div key={s.id} style={{textAlign:"center"}}>
                <div style={{fontSize:26,animation:`bobble ${1+i*0.3}s ease-in-out infinite`,animationDelay:`${i*0.2}s`}}>{s.emoji}</div>
                <div style={{fontSize:10,color:cfg.color,fontWeight:700,background:cfg.color+"22",borderRadius:4,padding:"1px 5px"}}>{s.name}</div>
              </div>
            ))}
          </div>
          {/* 손님 */}
          <div style={{position:"absolute",bottom:42,right:16,display:"flex",gap:6,alignItems:"flex-end"}}>
            {[...Array(Math.min(custCount,5))].map((_,i)=>(
              <div key={i} style={{textAlign:"center",animation:`bobble ${1.2+i*0.2}s ease-in-out infinite`,animationDelay:`${i*0.15}s`}}>
                <div style={{fontSize:20}}>{cfg.emojis[i%cfg.emojis.length]}</div>
                <div style={{fontSize:13}}>🪑</div>
              </div>
            ))}
            {custCount>5&&<div style={{fontSize:13,color:cfg.color,fontWeight:700,alignSelf:"center"}}>+{custCount-5}</div>}
          </div>
          {/* 하단 바 */}
          <div style={{position:"absolute",bottom:0,left:0,right:0,height:38,background:cfg.color+"18",borderTop:`1px solid ${cfg.color}33`,display:"flex",alignItems:"center",justifyContent:"space-between",padding:"0 16px"}}>
            <span style={{fontSize:13,color:cfg.color,fontWeight:700}}>{W[state.weather].icon} {W[state.weather].label}</span>
            <span style={{fontSize:12,color:G600}}>손님 {state.todayCustomers}명</span>
            <span style={{fontSize:13,color:state.todayProfit>=0?GREEN_M:RED_M,fontWeight:700}}>{state.todayProfit>=0?"+":""}{fmt(state.todayProfit)}</span>
          </div>
          {/* 플로팅 텍스트 */}
          {floats.map(f=>(
            <div key={f.id} style={{position:"absolute",top:"20%",left:`${f.x}%`,fontSize:16,fontWeight:800,color:f.color,pointerEvents:"none",animation:"floatUp 1.6s ease-out forwards",whiteSpace:"nowrap",zIndex:10}}>{f.text}</div>
          ))}
        </div>

        {/* 아침 */}
        {state.phase==="morning"&&(
          <div style={{...card,animation:"popIn 0.3s ease-out"}}>
            <div style={{display:"flex",gap:14,alignItems:"center",marginBottom:16}}>
              <div style={{fontSize:38,background:G50,borderRadius:50,width:58,height:58,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>🌅</div>
              <div>
                <p style={{fontSize:17,fontWeight:800,color:G900,margin:0}}>좋은 아침이에요!</p>
                <p style={{fontSize:13,color:G600,margin:"3px 0 0"}}>{W[state.weather].icon} {W[state.weather].label} — 손님 {W[state.weather].mod>=1?"많을":"적을"} 것 같아요</p>
              </div>
            </div>
            {state.staff.some(s=>s.absent)&&(
              <div style={{background:RED_L,border:`1px solid #FECACA`,borderRadius:12,padding:"10px 14px",marginBottom:12}}>
                <p style={{fontSize:14,color:RED_M,margin:0,fontWeight:600}}>😷 {state.staff.filter(s=>s.absent).map(s=>s.name).join(", ")} 결근!</p>
              </div>
            )}
            {state.day%30===0&&(
              <div style={{background:"#FFFBEB",border:"1px solid #FDE68A",borderRadius:12,padding:"10px 14px",marginBottom:12}}>
                <p style={{fontSize:14,color:"#92400E",margin:0,fontWeight:600}}>📅 오늘 월세 납부일! -{fmt(state.rent+state.utilities)}</p>
              </div>
            )}
            {state.streak>=3&&(
              <div style={{background:BLUE_LIGHT,border:`1px solid #BFDBFE`,borderRadius:12,padding:"10px 14px",marginBottom:12}}>
                <p style={{fontSize:14,color:BLUE_DARK,margin:0,fontWeight:600}}>🔥 {state.streak}일 연속 흑자 진행 중!</p>
              </div>
            )}
            {/* 직원 카드 */}
            <div style={{display:"grid",gridTemplateColumns:`repeat(${Math.min(state.staff.length,3)},1fr)`,gap:8,marginBottom:16}}>
              {state.staff.map(s=>(
                <div key={s.id} style={{background:G50,borderRadius:14,padding:"10px 8px",textAlign:"center",opacity:s.absent?0.35:1,border:`1px solid ${G200}`}}>
                  <div style={{fontSize:30,marginBottom:4}}>{s.emoji}</div>
                  <p style={{fontSize:13,color:G900,margin:"0 0 1px",fontWeight:600}}>{s.name}</p>
                  <p style={{fontSize:11,color:G400,margin:"0 0 6px"}}>{s.role}</p>
                  <div style={{background:G200,borderRadius:3,height:4,overflow:"hidden"}}>
                    <div style={{height:"100%",width:`${s.mood}%`,background:s.mood>=70?GREEN_M:s.mood>=40?"#F59E0B":RED_M,borderRadius:3}}/>
                  </div>
                  <p style={{fontSize:11,color:G400,margin:"3px 0 0"}}>사기 {s.mood}</p>
                </div>
              ))}
            </div>
            <button onClick={openDay} style={{...btn(cfg.color),padding:"16px 20px",fontSize:16,borderRadius:14}}>
              🚪 영업 시작! {isWeekend?"🎉 주말 특수!":""}
            </button>
          </div>
        )}

        {/* 이벤트 */}
        {state.phase==="event"&&state.currentEvent&&(
          <div style={{background:typeColor.bg,border:`1px solid ${typeColor.border}`,borderRadius:20,padding:20,animation:"popIn 0.3s ease-out"}}>
            <div style={{display:"flex",gap:14,marginBottom:16,alignItems:"flex-start"}}>
              <div style={{flexShrink:0,textAlign:"center"}}>
                <div style={{fontSize:42,background:"#fff",borderRadius:50,width:66,height:66,display:"flex",alignItems:"center",justifyContent:"center",border:`1px solid ${typeColor.border}`}}>{state.currentEvent.character}</div>
                <p style={{fontSize:11,color:typeColor.text,margin:"4px 0 0",fontWeight:700}}>{state.currentEvent.characterName}</p>
              </div>
              <div style={{flex:1}}>
                <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:8}}>
                  <span style={{...tag(typeColor.text,typeColor.lbg)}}>{typeColor.label}</span>
                  <span style={{fontSize:16}}>{state.currentEvent.icon}</span>
                </div>
                <p style={{fontSize:17,fontWeight:800,color:G900,margin:"0 0 8px"}}>{state.currentEvent.title}</p>
                <div style={{background:"#fff",borderRadius:"0 14px 14px 14px",padding:"12px 14px",border:`1px solid ${typeColor.border}`}}>
                  <p style={{fontSize:14,color:G800,lineHeight:1.6,margin:0}}>{state.currentEvent.desc}</p>
                </div>
              </div>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:8}}>
              {state.currentEvent.choices.map((c,i)=>(
                <button key={i} onClick={()=>handleChoice(i)} disabled={!!c.cost&&state.cash<c.cost}
                  style={{padding:"13px 16px",borderRadius:12,border:`1px solid ${typeColor.border}`,background:"#fff",cursor:c.cost&&state.cash<c.cost?"not-allowed":"pointer",textAlign:"left",opacity:c.cost&&state.cash<c.cost?0.4:1,fontFamily:"'Pretendard',sans-serif",transition:"background 0.15s"}}>
                  <p style={{fontSize:15,fontWeight:700,color:G900,margin:"0 0 3px"}}>{c.label}</p>
                  <p style={{fontSize:13,color:G600,margin:0}}>{c.desc}{c.cost?` · 💸 ${fmtFull(c.cost)}원`:""}</p>
                </button>
              ))}
            </div>
          </div>
        )}

        {/* 결과 */}
        {state.phase==="result"&&(
          <div style={{...card,border:`1px solid ${state.todayProfit>=0?"#A7F3D0":"#FECACA"}`,animation:"popIn 0.3s ease-out"}}>
            <div style={{textAlign:"center",marginBottom:16}}>
              <div style={{fontSize:46,marginBottom:8}}>{state.todayProfit>1000000?"🤑":state.todayProfit>0?"😊":state.todayProfit>-500000?"😬":"😭"}</div>
              <p style={{fontSize:14,color:state.todayProfit>=0?GREEN_M:RED_M,fontWeight:700,margin:"0 0 5px"}}>{state.day}일차 마감</p>
              <p style={{fontSize:30,fontWeight:800,color:state.todayProfit>=0?GREEN_M:RED_M,margin:0,letterSpacing:-0.5}}>{state.todayProfit>=0?"+ ":"- "}{fmtFull(Math.abs(state.todayProfit))}원</p>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:14}}>
              {[{l:"🧑‍🤝‍🧑 방문 고객",v:`${state.todayCustomers}명`,c:BLUE},{l:"💵 매출",v:`${fmtFull(state.todayRevenue)}원`,c:GREEN_M},{l:"💸 비용",v:`${fmtFull(state.todayCost)}원`,c:RED_M},{l:"🏦 잔고",v:`${fmtFull(state.cash)}원`,c:state.cash>=0?G900:RED_M}].map(s=>(
                <div key={s.l} style={{background:G50,borderRadius:12,padding:"11px 13px"}}>
                  <p style={{fontSize:12,color:G400,margin:"0 0 4px"}}>{s.l}</p>
                  <p style={{fontSize:15,fontWeight:700,color:s.c,margin:0}}>{s.v}</p>
                </div>
              ))}
            </div>
            {/* EXP 바 */}
            <div style={{background:G50,borderRadius:12,padding:"10px 13px",marginBottom:14}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5}}>
                <span style={{fontSize:13,color:G600,fontWeight:600}}>EXP +{calcExp(state.todayProfit)}</span>
                <span style={{fontSize:13,color:cfg.color,fontWeight:700}}>LV.{getLevel(state.exp)}</span>
              </div>
              <div style={{background:G200,borderRadius:4,height:6,overflow:"hidden"}}>
                <div style={{height:"100%",width:`${(state.exp%200)/2}%`,background:cfg.color,borderRadius:4,transition:"width 0.5s"}}/>
              </div>
            </div>
            <button onClick={nextDay} style={{...btn(cfg.color),padding:"16px",fontSize:16,borderRadius:14}}>
              {state.day>=state.maxDays?"🏆 최종 결산 보기":`${state.day+1}일차로 →`}
            </button>
          </div>
        )}

        {/* 최근 로그 */}
        {state.logs.length>0&&state.phase==="morning"&&(
          <div style={{...card,marginTop:10}}>
            <p style={{fontSize:13,color:G400,margin:"0 0 10px",fontWeight:600}}>📋 최근 기록</p>
            {state.logs.slice(-4).reverse().map(l=>(
              <div key={l.day} style={{display:"flex",justifyContent:"space-between",fontSize:13,padding:"6px 0",borderTop:`1px solid ${G100}`}}>
                <span style={{color:G400}}>{l.day}일 {W[l.weather].icon}</span>
                <span style={{color:G600,flex:1,margin:"0 10px",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{l.event??"평범한 하루"}</span>
                <span style={{color:l.profit>=0?GREEN_M:RED_M,fontWeight:700}}>{l.profit>=0?"+":"-"}{fmt(Math.abs(l.profit))}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

// ─── 게임오버 ─────────────────────────────────────────────────
function GameOver({state,onRestart,onMenu}:{state:GameState;onRestart:()=>void;onMenu:()=>void}){
  const grade=state.totalProfit>=150000000?"S":state.totalProfit>=80000000?"A":state.totalProfit>=30000000?"B":state.totalProfit>=0?"C":"D";
  const gd:{[k:string]:{emoji:string;msg:string;color:string}}={
    S:{emoji:"🏆",msg:"전설의 사장님!",color:"#F59E0B"},A:{emoji:"🥇",msg:"우수한 경영자!",color:GREEN_M},
    B:{emoji:"🥈",msg:"선방했어요!",color:BLUE},C:{emoji:"🥉",msg:"아슬아슬 흑자!",color:"#8B5CF6"},D:{emoji:"💸",msg:"다시 도전!",color:RED_M}
  };
  const g=gd[grade];
  const cfg=IND[state.industry];

  useEffect(()=>{deleteSave();},[]);

  return(
    <div style={{minHeight:"100vh",background:G50,fontFamily:"'Pretendard',sans-serif"}}>
      <style>{`@import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;500;600;700;800;900&display=swap');`}</style>
      <GameNavBar/>
      <div style={{maxWidth:480,margin:"0 auto",padding:"32px 20px"}}>
        <div style={{textAlign:"center",marginBottom:24}}>
          <div style={{fontSize:64,marginBottom:8}}>{g.emoji}</div>
          <div style={{fontSize:56,fontWeight:800,color:g.color,marginBottom:8,letterSpacing:-2}}>{grade}</div>
          <h2 style={{fontSize:24,fontWeight:800,color:G900,marginBottom:6}}>{g.msg}</h2>
          <p style={{fontSize:14,color:G600}}>{state.day}일 운영 · {state.storeName}</p>
        </div>
        <div style={{...card,marginBottom:16}}>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:16}}>
            {[{l:"누적 순이익",v:`${fmtFull(state.totalProfit)}원`,c:state.totalProfit>=0?GREEN_M:RED_M},{l:"최종 잔고",v:`${fmtFull(state.cash)}원`,c:state.cash>=0?G900:RED_M},{l:"총 매출",v:`${fmtFull(state.totalRevenue)}원`,c:BLUE},{l:"최고 하루",v:state.bestDay>0?fmt(state.bestDay):"없음",c:"#F59E0B"},{l:"최장 연속 흑자",v:`${state.streak}일`,c:"#8B5CF6"},{l:"도달 레벨",v:`LV.${getLevel(state.exp)}`,c:cfg.color}].map(s=>(
              <div key={s.l} style={{background:G50,borderRadius:12,padding:"11px 13px"}}>
                <p style={{fontSize:11,color:G400,margin:"0 0 4px"}}>{s.l}</p>
                <p style={{fontSize:15,fontWeight:700,color:s.c,margin:0}}>{s.v}</p>
              </div>
            ))}
          </div>
          <p style={{fontSize:13,color:G400,margin:"0 0 10px",fontWeight:600}}>최근 기록</p>
          {state.logs.slice(-8).reverse().map(l=>(
            <div key={l.day} style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderTop:`1px solid ${G100}`,fontSize:13}}>
              <span style={{color:G400}}>{l.day}일 {W[l.weather].icon}</span>
              <span style={{color:G600,flex:1,margin:"0 10px",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{l.event??"평범한 하루"}</span>
              <span style={{color:l.profit>=0?GREEN_M:RED_M,fontWeight:700}}>{l.profit>=0?"+":"-"}{fmt(Math.abs(l.profit))}</span>
            </div>
          ))}
        </div>
        <div style={{display:"flex",gap:8}}>
          <button onClick={onMenu} style={{...btnOutline(false),flex:1,padding:"14px",fontSize:14}}>🏠 메인으로</button>
          <button onClick={onRestart} style={{...btn(cfg.color,false),flex:2,padding:"14px",fontSize:15,borderRadius:12}}>🔄 다시 도전!</button>
        </div>
        <div style={{textAlign:"center",marginTop:12}}>
          <Link href="/simulator" style={{fontSize:13,color:BLUE,textDecoration:"none"}}>실제 시뮬레이터로 내 매장 분석해보기 →</Link>
        </div>
      </div>
    </div>
  );
}

// ─── 메인 엔트리 ─────────────────────────────────────────────
export default function GamePage(){
  const [gamePhase,setGamePhase]=useState<GamePhase>("menu");
  const [gameState,setGameState]=useState<GameState|null>(null);
  const [savedGame,setSavedGame]=useState<GameState|null>(null);

  useEffect(()=>{setSavedGame(loadGame());},[]);

  const handleLoad=()=>{
    const s=loadGame();
    if(s){setGameState(s);setGamePhase("playing");}
  };

  const handleSave=()=>{
    if(gameState){saveGame(gameState);alert("저장되었습니다! 💾");}
  };

  const handleGameOver=()=>{
    setGamePhase("gameover");
  };

  if(gamePhase==="menu")return<MainMenu onNew={()=>setGamePhase("setup")} onLoad={handleLoad} savedGame={savedGame}/>;
  if(gamePhase==="setup")return<GameSetup onStart={s=>{setGameState(s);setGamePhase("playing");}}/>;
  if(gamePhase==="gameover"&&gameState)return<GameOver state={gameState} onRestart={()=>setGamePhase("setup")} onMenu={()=>setGamePhase("menu")}/>;
  if(gamePhase==="playing"&&gameState)return(
    <GamePlay state={gameState} setState={setGameState as React.Dispatch<React.SetStateAction<GameState|null>>} onGameOver={handleGameOver} onSave={handleSave}/>
  );
  return null;
}
